generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  MAIN_ADMIN
  STAFF
}

enum Region {
  SPR
  SCPR
  NCPR
  NPR
  UNPR
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CLOSED
}

model User {
  id                 String    @id @default(cuid())
  fullName           String
  serviceNumber      String    @unique
  mobileNumber       String?
  username           String    @unique
  passwordHash       String
  rank               String?
  region             Region?
  role               Role
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  disabledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tasks Task[]
}

model Task {
  id                     String     @id @default(cuid())
  taskNumber             String     @unique
  date                   DateTime
  region                 Region
  atoll                  String
  island                 String?
  description            String
  informationProvided    String
  informationProvidedDate DateTime?
  status                 TaskStatus @default(PENDING)

  createdByUserId        String
  createdByName          String
  createdByServiceNumber String

  createdAt              DateTime   @default(now())
  updatedAt              DateTime   @updatedAt

  createdBy              User       @relation(fields: [createdByUserId], references: [id])
  sharedToOptions        TaskSharedToOption[]
  requestTypeOptions     TaskRequestTypeOption[]
}

model SharedToOption {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks TaskSharedToOption[]
}

model RequestTypeOption {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks TaskRequestTypeOption[]
}

model TaskSharedToOption {
  id               String @id @default(cuid())
  taskId           String
  sharedToOptionId String

  task           Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sharedToOption SharedToOption @relation(fields: [sharedToOptionId], references: [id], onDelete: Cascade)

  @@unique([taskId, sharedToOptionId])
}

model TaskRequestTypeOption {
  id                  String @id @default(cuid())
  taskId              String
  requestTypeOptionId String

  task              Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requestTypeOption RequestTypeOption @relation(fields: [requestTypeOptionId], references: [id], onDelete: Cascade)

  @@unique([taskId, requestTypeOptionId])
}