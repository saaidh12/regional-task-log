generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum Role {
  MAIN_ADMIN
  STAFF
}

enum Region {
  SPR
  SCPR
  NCPR
  NPR
  UNPR
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  CLOSED
}

enum InfoPriority {
  NORMAL
  IMPORTANT
  URGENT
}

enum SupportTicketStatus {
  OPEN
  IN_PROGRESS
  FIXED
  CLOSED
  REJECTED
}

enum SupportTicketPriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum SupportTicketCategory {
  BUG
  CHANGE_REQUEST
  LOGIN_ISSUE
  DATA_ISSUE
  IMAGE_UPLOAD
  OTHER
}

model User {
  id                 String    @id @default(cuid())
  fullName           String
  serviceNumber      String    @unique
  mobileNumber       String?
  username           String    @unique
  passwordHash       String
  rank               String?
  region             Region?
  role               Role
  isActive           Boolean   @default(true)
  mustChangePassword Boolean   @default(false)
  disabledAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tasks           Task[]
  personRecords   PersonRecord[]
  yaumiyyaRecords YaumiyyaRecord[]

  infoShares     InfoShare[]
  supportTickets SupportTicket[]
  ticketReplies  SupportTicketReply[]
}

model Task {
  id                      String     @id @default(cuid())
  taskNumber              String     @unique
  date                    DateTime
  region                  Region
  atoll                   String
  island                  String?
  description             String
  informationProvided     String
  informationProvidedDate DateTime?
  status                  TaskStatus @default(PENDING)

  createdByUserId        String
  createdByName          String
  createdByServiceNumber String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy          User                    @relation(fields: [createdByUserId], references: [id])
  sharedToOptions    TaskSharedToOption[]
  requestTypeOptions TaskRequestTypeOption[]
}

model SharedToOption {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks TaskSharedToOption[]
}

model RequestTypeOption {
  id        String   @id @default(cuid())
  name      String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks TaskRequestTypeOption[]
}

model TaskSharedToOption {
  id               String @id @default(cuid())
  taskId           String
  sharedToOptionId String

  task           Task           @relation(fields: [taskId], references: [id], onDelete: Cascade)
  sharedToOption SharedToOption @relation(fields: [sharedToOptionId], references: [id], onDelete: Cascade)

  @@unique([taskId, sharedToOptionId])
}

model TaskRequestTypeOption {
  id                  String @id @default(cuid())
  taskId              String
  requestTypeOptionId String

  task              Task              @relation(fields: [taskId], references: [id], onDelete: Cascade)
  requestTypeOption RequestTypeOption @relation(fields: [requestTypeOptionId], references: [id], onDelete: Cascade)

  @@unique([taskId, requestTypeOptionId])
}

/*
  PERSON DATABASE MODULE

  Rules:
  - Each person belongs to one region.
  - Staff can only see their own region records.
  - Main Admin can see all region records.
  - Crime categories are region-based.
*/

model PersonRecord {
  id String @id @default(cuid())

  photoUrl String?

  fullName     String
  idNumber     String?
  address      String?
  mobileNumber String?

  region Region
  atoll  String?
  island String?

  notes String?

  createdByUserId        String
  createdByName          String
  createdByServiceNumber String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy       User                  @relation(fields: [createdByUserId], references: [id])
  nicknames       PersonNickname[]
  crimeCategories PersonCrimeCategory[]

  @@index([region])
  @@index([fullName])
  @@index([idNumber])
  @@index([mobileNumber])
}

model PersonNickname {
  id       String @id @default(cuid())
  personId String
  name     String

  person PersonRecord @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@index([name])
}

model CrimeCategory {
  id       String  @id @default(cuid())
  name     String
  region   Region
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  people PersonCrimeCategory[]

  @@unique([name, region])
  @@index([region])
}

model PersonCrimeCategory {
  id              String @id @default(cuid())
  personId        String
  crimeCategoryId String

  person        PersonRecord  @relation(fields: [personId], references: [id], onDelete: Cascade)
  crimeCategory CrimeCategory @relation(fields: [crimeCategoryId], references: [id], onDelete: Cascade)

  @@unique([personId, crimeCategoryId])
}

/*
  YAUMIYYA MODULE

  Meaning:
  - Yaumiyya = meeting notes.
  - Region based.
  - Staff can only see own region records.
  - Main Admin can see all regions.
*/

model YaumiyyaRecord {
  id String @id @default(cuid())

  date         DateTime
  startTime    String?
  finishedTime String?
  region       Region
  meetingTitle String?

  meetingNotes  String
  assignedTasks String?

  createdByUserId        String
  createdByName          String
  createdByServiceNumber String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy    User                    @relation(fields: [createdByUserId], references: [id])
  participants YaumiyyaParticipant[]

  @@index([region])
  @@index([date])
}

model YaumiyyaParticipant {
  id         String @id @default(cuid())
  yaumiyyaId String

  userId      String?
  displayName String
  serviceNo   String?
  region      Region?

  yaumiyya YaumiyyaRecord @relation(fields: [yaumiyyaId], references: [id], onDelete: Cascade)

  @@index([yaumiyyaId])
  @@index([displayName])
}

/*
  INFORMATION SHARED MODULE

  Meaning:
  - This is not a task.
  - It is for information received and shared to regions/areas.
  - Main Admin can manage shared areas.
*/

model InfoShare {
  id String @id @default(cuid())

  date    DateTime
  title   String
  details String

  source   String?
  remarks  String?
  priority InfoPriority @default(NORMAL)

  createdByUserId        String
  createdByName          String
  createdByServiceNumber String
  createdByRegion        Region?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy     User              @relation(fields: [createdByUserId], references: [id])
  sharedToAreas InfoShareToArea[]

  @@index([date])
  @@index([createdByRegion])
  @@index([priority])
}

model InfoShareArea {
  id       String  @id @default(cuid())
  name     String  @unique
  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  infoShares InfoShareToArea[]
}

model InfoShareToArea {
  id          String @id @default(cuid())
  infoShareId String
  areaId      String

  infoShare InfoShare     @relation(fields: [infoShareId], references: [id], onDelete: Cascade)
  area      InfoShareArea @relation(fields: [areaId], references: [id], onDelete: Cascade)

  @@unique([infoShareId, areaId])
  @@index([areaId])
}

/*
  SUPPORT TICKET MODULE

  Meaning:
  - Users can create technical support tickets.
  - Main Admin can view all tickets, reply, update status and close.
  - Users can upload screenshots/attachments.
*/

model SupportTicket {
  id String @id @default(cuid())

  ticketNumber String @unique
  subject      String
  details      String

  category SupportTicketCategory @default(OTHER)
  priority SupportTicketPriority @default(NORMAL)
  status   SupportTicketStatus   @default(OPEN)

  createdByUserId        String
  createdByName          String
  createdByServiceNumber String
  createdByRegion        Region?

  assignedToUserId String?
  assignedToName   String?

  adminNote String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy   User                      @relation(fields: [createdByUserId], references: [id])
  replies     SupportTicketReply[]
  attachments SupportTicketAttachment[]

  @@index([status])
  @@index([priority])
  @@index([category])
  @@index([createdByRegion])
  @@index([createdByUserId])
}

model SupportTicketReply {
  id       String @id @default(cuid())
  ticketId String

  message String

  createdByUserId        String
  createdByName          String
  createdByServiceNumber String

  createdAt DateTime @default(now())

  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  createdBy User          @relation(fields: [createdByUserId], references: [id])

  @@index([ticketId])
}

model SupportTicketAttachment {
  id       String @id @default(cuid())
  ticketId String

  fileUrl  String
  fileName String
  fileType String
  fileSize Int

  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
}